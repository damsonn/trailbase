# Database
DATABASE_URL=postgres://trailbase:password@localhost:5432/trailbase

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Map tiles
MAP_PROVIDER=mapbox              # mapbox | osm | custom
MAPBOX_ACCESS_TOKEN=pk.xxx       # only if MAP_PROVIDER=mapbox

# Routing
ROUTING_ENGINE=valhalla          # valhalla | osrm | graphhopper | mapbox
VALHALLA_URL=http://localhost:8002

# Elevation
ELEVATION_PROVIDER=mapbox        # mapbox | open-elevation
OPEN_ELEVATION_URL=http://localhost:8080

# Auth (Better-Auth)
BETTER_AUTH_SECRET=change-me-to-a-random-string
